# Email (Resend) — required for contact form
RESEND_API_KEY=

# Database (Supabase) — optional, leads stored if configured
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Notifications (Slack) — optional, notifications sent if configured
SLACK_BOT_TOKEN=
SLACK_FORM_INTAKE_CHANNEL_ID=
# Legacy/fallback Slack channel name used by older helpers
SLACK_CHANNEL_ID=

# Analytics — GA4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Analytics — Meta Pixel (client-side, consent-gated)
NEXT_PUBLIC_META_PIXEL_ID=

# Analytics — Meta CAPI (server-side)
META_ACCESS_TOKEN=
META_PIXEL_ID=

# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GADS_LEAD_LABEL=
NEXT_PUBLIC_GADS_WHATSAPP_LABEL=
# Optional guard used to detect the wrong Google Ads tag at runtime
NEXT_PUBLIC_EXPECTED_GOOGLE_ADS_TAG=

# Paid-search WhatsApp/router tagging
FREIGHT_ROUTER_TAG=

# Google Sheets — shared shipping schedule sync
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_TAB_NAME=

# Search Engine Verification — paste codes from Google Search Console / Bing Webmaster
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# IndexNow — instant Bing/Yandex indexing
INDEXNOW_KEY=
INDEXNOW_SECRET=

# Cron Jobs — protects cron endpoints from unauthorized access
CRON_SECRET=

# Error Tracking (Sentry) — optional, errors captured if configured
# Get DSN from: https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload (build-time only, not needed locally)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
